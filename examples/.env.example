# IOC CFN MAS Client Library - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# CFN Service Configuration
# =============================================================================
# Base URL for the CFN service API
CFN_BASE_URL=http://localhost:9010

# Optional: API key for CFN service authentication
# Leave empty if authentication is not required
CFN_API_KEY=

# =============================================================================
# Management Plane Configuration
# =============================================================================
# Base URL for the Management Plane API
MANAGEMENT_PLANE_BASE_URL=http://localhost:8080

# API key for Management Plane authentication (X-API-Key header)
API_KEY=your-api-key-here

# =============================================================================
# Optional: Connection Settings
# =============================================================================
# Request timeout in seconds (optional)
# REQUEST_TIMEOUT=30
